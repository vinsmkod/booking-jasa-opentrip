{
    "name": "opentrip/project",
    "type": "project",
    "description": "OpenTrip CI4 project",
    "require": {
        "php": "^7.3 || ^8.0",
        "ext-curl": "*",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "kint-php/kint": "^3.3",
        "laminas/laminas-escaper": "^2.6",
        "psr/log": "^1.1",
        "codeigniter4/framework": "^4.2",
        "dompdf/dompdf": "^3.1",
        "phpoffice/phpspreadsheet": "^5.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^9.1",
        "predis/predis": "^1.1",
        "squizlabs/php_codesniffer": "^3.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "CodeIgniter\\": "system/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "CodeIgniter\\ComposerScripts::postUpdate"
        ],
        "test": "phpunit"
    }
}
